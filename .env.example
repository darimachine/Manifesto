# Manifesto configuration — copy to .env and adjust.
# ALL application settings live here (single place, per course requirement).

# --- Database (XAMPP defaults: root / empty password) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=manifesto
DB_USER=root
DB_PASS=

# --- Application ---
# APP_DEBUG=1 shows errors on screen; set 0 for the exam demo.
APP_DEBUG=1

# --- Docker deployment only (used by docker-compose.yml, not by XAMPP) ---
APP_HTTP_PORT=8080
DB_ROOT_PASSWORD=manifesto_root
DB_EXPOSED_PORT=33060
